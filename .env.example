# ===== Worker connection =====
WORKER_BASE_URL=https://llms-news.xtower.site
WORKER_SHARED_TOKEN=change-me

# ===== Local storage =====
SQLITE_PATH=./data/news.db
# Tier routing file for P0/P1/P2 mapping and tier score thresholds
SOURCE_TIER_CONFIG=./config/source_tiers.json

# ===== Harvest behavior =====
# Fallback count if /sources is unavailable
MAX_SHARDS=6
# Page size for each /fetch call
WORKER_PAGE_SIZE=10
# Run full harvest multiple rounds (for "trigger one more round")
HARVEST_ROUNDS=1
# Sleep between rounds (seconds)
ROUND_SLEEP_SECS=4
# Only notify candidates with score >= threshold
CANDIDATE_MIN_SCORE=70
ALERT_RETRY_MAX_ATTEMPTS=6
ALERT_RETRY_BASE_SECS=120
SEMANTIC_DEDUPE_LOOKBACK_HOURS=72

# ===== Notification =====
# Empty = print only
NOTIFY_WEBHOOK=

# ===== Small LLM filter (all news pass this stage) =====
# Used to decide if one item is AI-related.
SMALL_LLM_API_BASE=
SMALL_LLM_API_KEY=
SMALL_LLM_MODEL=
# auto = try /responses first, fallback to /chat/completions only on protocol-mismatch errors
# responses = use /responses only
# chat = use /chat/completions only
SMALL_LLM_API_PROTOCOL=auto
SMALL_LLM_CONCURRENCY=8

# ===== Big LLM rewrite/classification (Chinese output) =====
# Used to rewrite into readable Chinese summary and final category.
BIG_LLM_API_BASE=
BIG_LLM_API_KEY=
BIG_LLM_MODEL=
BIG_LLM_API_PROTOCOL=auto
# 0 = process all candidates after small-LLM filtering
BIG_LLM_MAX_ITEMS=0
BIG_LLM_CONCURRENCY=4

# ===== Legacy compatibility (optional) =====
# If BIG_LLM_* is empty, scheduler falls back to these old vars.
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
LLM_API_PROTOCOL=auto
LLM_MAX_ITEMS=8
